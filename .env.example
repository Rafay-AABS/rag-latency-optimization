# Groq API Configuration (Required)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace Token (Optional)
HF_TOKEN=your_huggingface_token_here

# Langfuse Configuration (Optional - for observability)
# If running Langfuse locally on Docker, use:
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# Note: Get your Langfuse keys from your local instance at http://localhost:3000
# Navigate to Settings -> API Keys to create new keys
